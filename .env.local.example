# Encryption key for API keys stored by the app (generate with: openssl rand -hex 32)
ENCRYPTION_KEY=your-64-char-hex-encryption-key

# Local auth session signing key (generate with: openssl rand -hex 32)
AUTH_SECRET=your-64-char-hex-auth-secret

# Cookie behavior override (optional): true/false. If unset, secure cookies are used in production only.
COOKIE_SECURE=

# Allow user self-signup endpoint (recommended false in production)
ALLOW_SIGNUP=false

# Optional initial admin bootstrap (used only when .data/users.json is empty)
LOCAL_ADMIN_EMAIL=admin@example.com
LOCAL_ADMIN_PASSWORD=change-me-please

# Optional ingest safety controls
PERSONA_INGEST_MAX_ACTIVE_JOBS=3
OUTBOUND_FETCH_TIMEOUT_MS=15000

# Optional OCI IAM OIDC settings
AUTH_OCI_CLIENT_SECRET=
OCI_ADMIN_EMAILS=admin@example.com

# Oracle ADB-S connection (required)
ORACLE_USER=
ORACLE_PASSWORD=
ORACLE_CONNECT_STRING=

# Optional TLS-in-container mode (self-signed cert generated on startup)
ENABLE_SELF_SIGNED_TLS=false
APP_INTERNAL_PORT=3001
